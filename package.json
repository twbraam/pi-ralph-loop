{
  "name": "@lnilluv/pi-ralph-loop",
  "version": "1.6.2",
  "description": "Pi-native ralph loop — autonomous coding iterations with mid-turn supervision",
  "type": "module",
  "pi": {
    "extensions": [
      "./src/index.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "engines": {
    "node": ">=22.22.1"
  },
  "scripts": {
    "test": "node --test --experimental-strip-types $(find tests -type f -name '*.ts' | sort)",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lnilluv/pi-ralph-loop.git"
  },
  "dependencies": {
    "@mariozechner/pi-ai": "0.66.1",
    "minimatch": "10.2.3",
    "yaml": "2.8.3"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": ">=0.69.0"
  },
  "overrides": {
    "basic-ftp": "5.3.0",
    "fast-xml-parser": "5.7.1",
    "protobufjs": "7.5.5"
  },
  "keywords": [
    "pi-extension",
    "pi-package",
    "ralph",
    "autonomous",
    "loop"
  ],
  "license": "MIT",
  "files": [
    "README.md",
    "examples",
    "presets",
    "skills",
    "src"
  ],
  "devDependencies": {
    "@types/node": "25.6.0",
    "typescript": "6.0.2"
  }
}
